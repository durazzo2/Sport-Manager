run = "php -S 0.0.0.0:8000 -t public"
entrypoint = "public/index.php"
modules = ["php-8.4", "nodejs-20"]

[nix]
channel = "stable-22_11"

[deployment]
run = ["php", "artisan", "serve", "--host=0.0.0.0", "--port=5000"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && php artisan serve --host=0.0.0.0 --port=8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"

[userenv]

[userenv.shared]
APP_ENV = "production"
APP_DEBUG = "false"
